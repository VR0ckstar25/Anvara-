{
  "expo": {
    "name": "Smart Food Scanner",
    "slug": "sfis-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "newArchEnabled": false,
    "splash": { "backgroundColor": "#E9F3FB" },
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "backgroundColor": "#E9F3FB" }, "permissions": ["CAMERA"] },
    "plugins": [["expo-camera", { "cameraPermission": "Allow Smart Food Scanner to use the camera to read ingredient labels." }]]
  }
}
